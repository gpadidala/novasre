# ============================================================
# NovaSRE — .gitignore
# ============================================================

# --- Secrets / Environment ---
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
.Python

# --- Python Tools ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
*.cover
.hypothesis/

# --- Type Stubs ---
*.pyi

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/
*.tsbuildinfo
.eslintcache

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker Volumes (local dev data) ---
pgdata/
chromadata/
redis-data/

# --- IDE / OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# --- Alembic (auto-generated) ---
# Keep alembic/versions/ checked in
# but ignore generated migration cache
alembic/__pycache__/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Profiling ---
*.prof
*.lprof

# --- K8s secrets (never commit) ---
k8s/secrets/
k8s/**/*secret*.yaml

# --- Terraform (if added later) ---
*.tfstate
*.tfstate.backup
.terraform/
