# ============================================================
# NovaSRE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# === LLM ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL_PRIMARY=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# === Database ===
DATABASE_URL=postgresql+asyncpg://novasre:secret@localhost:5432/novasre
REDIS_URL=redis://localhost:6379/0

# === Grafana Enterprise ===
GRAFANA_URL=https://grafana.your-org.com
GRAFANA_API_KEY=eyJrIj...
GRAFANA_ORG_ID=1

# === Mimir (Prometheus-compatible long-term metrics) ===
MIMIR_URL=https://mimir.your-org.com
MIMIR_TENANT_ID=your-tenant
MIMIR_BASIC_AUTH_USER=
MIMIR_BASIC_AUTH_PASSWORD=

# === Loki (Log aggregation) ===
LOKI_URL=https://loki.your-org.com
LOKI_TENANT_ID=your-tenant

# === Tempo (Distributed tracing) ===
TEMPO_URL=https://tempo.your-org.com
TEMPO_TENANT_ID=your-tenant

# === Pyroscope (Continuous profiling) ===
PYROSCOPE_URL=https://pyroscope.your-org.com
PYROSCOPE_API_KEY=

# === Faro (Real User Monitoring / Frontend Observability) ===
FARO_COLLECTOR_URL=https://faro-collector.your-org.com
FARO_API_KEY=

# === MCP Server ===
MCP_SERVER_URL=http://localhost:8001
MCP_SERVER_API_KEY=

# === Alertmanager ===
ALERTMANAGER_URL=https://alertmanager.your-org.com

# === Vector Store (ChromaDB) ===
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_COLLECTION_INCIDENTS=novasre_incidents
CHROMA_COLLECTION_RUNBOOKS=novasre_runbooks

# === Application Config ===
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# === Alert Correlation Tuning ===
CORRELATION_TEMPORAL_WINDOW_SECONDS=300
CORRELATION_SEMANTIC_THRESHOLD=0.75
CORRELATION_TOPOLOGICAL_DEPTH=3
